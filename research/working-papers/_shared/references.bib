  title        = {Democracy and Education: An Introduction to the Philosophy of Education},
  author       = {Dewey, John},
  publisher    = {Macmillan},
  address      = {New York},
  year         = {1916},
  note         = {Articulates democracy not as a procedural form of government but substantively as ``a mode of associated living, of conjoint communicated experience.'' The formulation is adopted nearly verbatim by B.~R.~Ambedkar in \emph{Annihilation of Caste} (1936) and becomes the analytical core of his constitutional-democratic project for India.}
}

@book{ambedkar1936annihilation,
