  author       = {Ambedkar, B. R.},
  editor       = {Anand, S.},
  publisher    = {Navayana},
  address      = {New Delhi},
  year         = {2014},
  note         = {Originally composed as the presidential address for the 1936 Annual Conference of the Jat-Pat Todak Mandal of Lahore but never delivered (the invitation was withdrawn after the organisers read the manuscript). First published as a pamphlet in 1936. The Navayana annotated edition includes an introduction by Arundhati Roy and substantial scholarly apparatus. The definition of democracy as ``primarily a mode of associated living, of conjoint communicated experience'' appears in §14.}
}

@book{stroud2023pragmatism,
  title        = {The Evolution of Pragmatism in India: {Ambedkar}, {Dewey}, and the Rhetoric of Reconstruction},
  author       = {Stroud, Scott R.},
  publisher    = {University of Chicago Press},
  address      = {Chicago},
  year         = {2023},
  note         = {Traces the Dewey--Ambedkar intellectual relationship from Ambedkar's Columbia years (1913--1916) through his constitutional and Buddhist writings, with attention to the translation of Dewey's ``associated living'' into Ambedkar's framework of maitri\,---\,the first of the Four Sublime States in the Buddhist ethical tradition, conventionally rendered as fellowship without barriers of caste, gender, or birth.}
}

@book{dreze_sen_2013,
  title        = {An Uncertain Glory: India and Its Contradictions},
  author       = {Dr{\`e}ze, Jean and Sen, Amartya},
  publisher    = {Princeton University Press},
  address      = {Princeton},
  year         = {2013},
  note         = {Argues that India's social-sector performance lags its economic-growth performance because the institutional infrastructures of public action --- schools, health centres, libraries, panchayat capacity, civic organisations --- have not been built to scale. The rights-based statutes of the UPA period are read as dependent on civic capacity that the architecture itself did not supply.}
}

@article{aga_choudhury_2018_rti,
  title        = {A Dappled Sun: Bureaucratic Encounters in the Working of the {Right} to {Information} {Act} in {India}},
  author       = {Aga, Aniket and Choudhury, Chitrangada},
  journal      = {Comparative Studies of South Asia, Africa and the Middle East},
  volume       = {38},
  number       = {3},
  pages        = {540--556},
  year         = {2018},
  doi          = {10.1215/1089201x-7208856},
  note         = {Ethnographic account of the uneven implementation of the RTI Act 2005 across bureaucratic settings. Documents how the demand-side requirements of using the right (literacy, documentation, sustained engagement) systematically advantage already-literate constituencies and disadvantage the populations the Act was designed to empower. Relevant for the argument that rights statutes presuppose civic-infrastructural capacity that the architecture itself does not supply.}
}

@article{rawat2024dalitpublic,
  title        = {Recovering the {Dalit} {Public} {Sphere}: {Vernacular} {Liberalism} in {Late} {Colonial} {North} {India}},
  author       = {Rawat, Ramnarayan S.},
  journal      = {Comparative Studies in Society and History},
  volume       = {66},
  number       = {3},
  pages        = {700--725},
  year         = {2024},
  doi          = {10.1017/S0010417524000021},
  note         = {Recovers the language and categories of liberalism developed in Hindi vernacular by Dalit poet-activists of the Adi-Hindu Mahasabha and Swami Achutanand's press, 1916--1940. Documents the emergence of a Dalit literate public sustained by song-booklets and mohalla-level chapbook circulation. Analytically central to the longue-dur\'{e}e reading of the public-library function as the institutional infrastructure of an anti-caste reading public, against the longer historical inheritance of caste-coded textual exclusion.}
}

@book{teltumbde2018republic,
  title        = {Republic of Caste: Thinking Equality in the Time of Neoliberal Hindutva},
  author       = {Teltumbde, Anand},
  publisher    = {Navayana},
  address      = {New Delhi},
  year         = {2018},
  isbn         = {978-81-89059-84-2},
  note         = {Identifies the watershed moments of post-Independence India --- from the Constitution-making compromise through the Green Revolution, the OBC upsurge, the rise of regional parties, and the post-1991 consolidation --- as elements of a single neoliberal-Hindutva complex that consolidates caste hegemony through the procedural dismantling of redistributive institutional arrangements. The framework reads contemporary state action as a politics of capturing the rhetorical surfaces of equality while procedurally emptying the substance, with Dalit and Adivasi constituencies as the structurally excluded.}
}

@article{banaji2022bigbusiness,
